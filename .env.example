# --- BASE DE DATOS (Valores fijos para docker-compose.yml) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=odemiro_db
DB_USER=odemiro
DB_PASS=odemiro_pass_2026
MYSQL_ROOT_PASSWORD=root_pass_2026

# --- API KEYS (OBLIGATORIAS - Consíguelas gratis) ---
# 1. NVIDIA Nemotron 3 Ultra (Gratis): https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=tu_nvidia_api_key_aqui

# 2. Google Gemini 3.5 Flash (Gratis): https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui

# 3. Anthropic Claude (Opcional, Pago): https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-tu_key_aqui

# --- RUTAS (Se auto-detectan en WSL/Linux) ---
# ODEM_BASE_PATH=/mnt/c/Users/TU_USER/OneDrive/Documentos/ODEM_PORTATIL